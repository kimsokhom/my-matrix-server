# =============================================================================
# GLOBAL / SHARED
# =============================================================================
SERVER_NAME=                          # Matrix domain, no https:// (used by almost all services)
GATEWAY_URL=                          # Full URL of IAM/Gateway service e.g. https://gateway.yourdomain.com

# =============================================================================
# DATABASE (shared PostgreSQL — each service should use its own DB name)
# =============================================================================
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres.railway.internal
POSTGRES_PORT=5432
SYNAPSE_DB_NAME=synapse
TELEGRAM_DB_NAME=telegram
# MAS uses POSTGRES_DB
POSTGRES_DB=mas

# =============================================================================
# SYNAPSE
# =============================================================================
MACAROON_KEY=                         # Random secret (openssl rand -hex 32)
FORM_SECRET=                          # Random secret (openssl rand -hex 32)
REGISTRATION_SHARED_SECRET=           # Random secret — shared with Telegram bridge & Postmoogle
SYNAPSE_INTERNAL_URL=http://synapse.railway.internal:8008
SYNAPSE_URL=                          # Public URL e.g. https://matrix.yourdomain.com

# MAS <-> Synapse
MAS_INTERNAL_URL=http://mas.railway.internal:8080
MAS_SHARED_SECRET=                    # Random secret — must match MAS service

# Bridge tokens — must match values in each bridge service
HOOKSHOT_AS_TOKEN=                    # openssl rand -hex 32
HOOKSHOT_HS_TOKEN=                    # openssl rand -hex 32
HOOKSHOT_INTERNAL_URL=http://hookshot.railway.internal:9993
TELEGRAM_AS_TOKEN=                    # openssl rand -hex 32
TELEGRAM_HS_TOKEN=                    # openssl rand -hex 32
TELEGRAM_BRIDGE_URL=http://telegram.railway.internal:29317

# =============================================================================
# MAS (Matrix Authentication Service)
# =============================================================================
MAS_URL=                              # Public base URL of MAS e.g. https://matrix.yourdomain.com
MAS_ENCRYPTION_SECRET=                # Random secret (openssl rand -hex 32)
MAS_RSA_PRIVATE_KEY=                  # RSA PEM key with literal \n escapes (printf '%b' to expand)
MAS_CLIENT_ID=mas-client
MAS_CLIENT_SECRET=                    # Random secret
MAS_IAM_SERVICE_SECRET=               # Random secret (openssl rand -hex 32) — used by IAM service client in MAS
ELEMENT_WEB_CLIENT_ID=element-web
ELEMENT_WEB_URL=                      # Public URL of Element Web e.g. https://matrix.yourdomain.com

# Upstream OIDC provider (Hydra)
MAS_UPSTREAM_HYDRA_PROVIDER_ID=       # A valid ULID e.g. 01JQ2Y5YJ7K4C8R9N6T3V1W2XA
MAS_UPSTREAM_HYDRA_ISSUER=            # Hydra issuer URL e.g. https://hydra.yourdomain.com
MAS_UPSTREAM_HYDRA_CLIENT_ID=mas-client
MAS_UPSTREAM_HYDRA_CLIENT_SECRET=     # Client secret registered in Hydra for MAS

# =============================================================================
# NGINX (reverse proxy)
# =============================================================================
HYDRA_HOST=                           # Hydra public hostname only, no https:// e.g. hydra.yourdomain.com
NGINX_ENVSUBST_FILTER=$$HYDRA_HOST $$GATEWAY_URL $$DNS_RESOLVER   # Controls which vars envsubst replaces

# =============================================================================
# ELEMENT WEB
# =============================================================================
POSTMOOGLE_WIDGET_URL=                # Public URL of postmoogle-widget e.g. https://widget.yourdomain.com

# =============================================================================
# ELEMENT CALL
# =============================================================================
LIVEKIT_SERVICE_URL=                  # LiveKit JWT service HTTP URL e.g. https://livekit.yourdomain.com
LIVEKIT_WSS_URL=                      # LiveKit WebSocket URL e.g. wss://livekit.yourdomain.com

# =============================================================================
# HOOKSHOT
# =============================================================================
LOG_LEVEL=info
GITLAB_WEBHOOK_SECRET=                # Random secret for validating GitLab webhook payloads
HOOKSHOT_PUBLIC_URL=                  # Public hostname for GitLab callbacks (no https://)

# =============================================================================
# TELEGRAM BRIDGE
# =============================================================================
TELEGRAM_API_ID=                      # From https://my.telegram.org
TELEGRAM_API_HASH=                    # From https://my.telegram.org
ADMIN_MXID=                           # Full Matrix ID of bridge admin e.g. @admin:yourdomain.com

# =============================================================================
# POSTMOOGLE
# =============================================================================
POSTMOOGLE_HOMESERVER=http://synapse.railway.internal:8008
POSTMOOGLE_LOGIN=                     # Bot's Matrix username e.g. postmoogle
POSTMOOGLE_SHAREDSECRET=              # Must match REGISTRATION_SHARED_SECRET
POSTMOOGLE_DOMAINS=                   # Email domain(s) comma-separated e.g. mail.yourdomain.com
POSTMOOGLE_PORT=25                    # SMTP port to listen on
POSTMOOGLE_DB_DSN=/data/postmoogle.db # SQLite path or PostgreSQL DSN
POSTMOOGLE_DATA_SECRET=               # Random secret for encrypting account data at rest
POSTMOOGLE_ADMINS=                    # Comma-separated Matrix user IDs e.g. @admin:yourdomain.com
POSTMOOGLE_LOGLEVEL=info

# Widget API (your fork)
POSTMOOGLE_WIDGET_API_ENABLED=true
POSTMOOGLE_WIDGET_API_PORT=8080
POSTMOOGLE_WIDGET_API_SECRET=         # Must match VITE_WIDGET_SECRET in postmoogle-widget

# SMTP relay (outbound mail — optional)
POSTMOOGLE_RELAY_HOST=
POSTMOOGLE_RELAY_PORT=587
POSTMOOGLE_RELAY_USERNAME=
POSTMOOGLE_RELAY_PASSWORD=

# DKIM signing (optional)
POSTMOOGLE_DKIM_PRIVKEY=              # PEM private key for DKIM signing
POSTMOOGLE_DKIM_SIGNATURE=            # DKIM selector e.g. postmoogle

# =============================================================================
# POSTMOOGLE WIDGET (Vite — baked in at build time)
# =============================================================================
VITE_POSTMOOGLE_BACKEND_URL=          # Public URL of Postmoogle service e.g. https://postmoogle.yourdomain.com
VITE_WIDGET_SECRET=                   # Must match POSTMOOGLE_WIDGET_API_SECRET

# =============================================================================
# PROVISIONING SERVICE
# =============================================================================
HOMESERVER_URL=http://synapse.railway.internal:8008
ADMIN_ACCESS_TOKEN=                   # Matrix admin bot access token (syt_xxx...)
WIDGET_URL=                           # Public URL of postmoogle-widget
WIDGET_ICON=                          # MXC URL of widget/room avatar e.g. mxc://yourdomain.com/abc
BOT_USER_ID=                          # Full Matrix ID of Postmoogle bot e.g. @postmoogle:yourdomain.com
PROVISIONING_SERVICE_PORT=3000
